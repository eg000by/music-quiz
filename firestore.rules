rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Лобби может читать и менять любой авторизованный пользователь.
    // Для дружеской игры на двоих этого достаточно.
    match /lobbies/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Профили и статистика игроков для таблицы лидеров.
    // Читать рейтинг может любой авторизованный, писать — только в свой документ.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
