rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Максимум очков за одну партию: 15 раундов (максимум ползунка) ×
    // (100 за мгновенный ответ по названию + 50 за точный год) = 2250. Берём с запасом.
    function maxGameScore() { return 2500; }

    // Лобби живёт ограниченное время (см. LOBBY_TTL_MS в src/services/lobby.js).
    function lobbyTtl() { return duration.value(6, 'h'); }

    // См. MAX_PLAYERS в src/services/lobby.js.
    function maxPlayers() { return 4; }

    // Базовая валидность документа профиля: только ожидаемые поля, имя/фото разумного
    // размера, счётчики — неотрицательные целые, побед не больше партий, история партий
    // ограничена 100 элементами.
    function validUserData(data) {
      return data.keys().hasOnly(['uid', 'name', 'photo', 'totalScore', 'gamesPlayed', 'wins', 'recordedGames', 'updatedAt', 'dailyStreak', 'dailyLast'])
        && data.name is string && data.name.size() <= 100
        && (data.photo == null || (data.photo is string && data.photo.size() <= 500))
        && data.totalScore is int && data.totalScore >= 0
        && data.gamesPlayed is int && data.gamesPlayed >= 0
        && data.wins is int && data.wins >= 0
        && data.wins <= data.gamesPlayed
        && (!('recordedGames' in data)
            || (data.recordedGames is list && data.recordedGames.size() <= 100))
        // стрик «Трека дня»: счётчик + дата последней партии (YYYY-MM-DD)
        && (!('dailyStreak' in data) || (data.dailyStreak is int && data.dailyStreak >= 0))
        && (!('dailyLast' in data) || (data.dailyLast is string && data.dailyLast.size() <= 10));
    }

    // Лобби: читать может любой авторизованный (нужно гостям по коду).
    match /lobbies/{code} {
      allow read: if signedIn();

      // Создать можно только своё лобби в статусе waiting и только с собой в составе.
      // createdAt — строго серверное время: иначе можно поставить дату в будущем и
      // сделать «вечное» лобби, которое не попадёт под TTL-чистку.
      allow create: if signedIn()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.createdAt == request.time
        && request.resource.data.players.keys().hasOnly([request.auth.uid]);

      // Верхнеуровневые ключи, изменённые этой записью.
      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }
      // В map-поле `field` изменился только свой ключ (учитываем, что поля может
      // ещё не быть — например, clockPings создаётся при первой синхронизации часов).
      function onlyOwn(field) {
        return !(field in request.resource.data) ? true
          : !(field in resource.data) ? request.resource.data[field].keys().hasOnly([request.auth.uid])
          : request.resource.data[field].diff(resource.data[field]).affectedKeys().hasOnly([request.auth.uid]);
      }

      // Свой объект игрока (если после записи он остаётся в составе): только ожидаемые
      // поля и разумные размеры — чтобы участник не мог раздуть документ лобби к лимиту
      // 1 МБ и сломать игру всем.
      function ownPlayerOk() {
        return !(request.auth.uid in request.resource.data.players)
          || (
            request.resource.data.players[request.auth.uid].keys().hasOnly(['uid', 'name', 'photo', 'score', 'ready', 'packs', 'anon'])
            && request.resource.data.players[request.auth.uid].name is string
            && request.resource.data.players[request.auth.uid].name.size() <= 100
            && request.resource.data.players[request.auth.uid].packs is list
            && request.resource.data.players[request.auth.uid].packs.size() <= 30
          );
      }

      // Свой счёт менять нельзя — его начисляет хост на reveal. Сравниваем только если
      // игрок остаётся в составе: при выходе из лобби поля players[uid] в новой версии
      // нет, и безусловное сравнение роняло бы запись выхода.
      function ownScoreUnchanged() {
        return !(request.auth.uid in request.resource.data.players)
          || request.resource.data.players[request.auth.uid].score
             == resource.data.players[request.auth.uid].score;
      }

      // Свой ответ: очки в допустимых пределах, и очки за название — только при верном
      // варианте (correctIndex текущего раунда лежит в этом же документе). Подделать
      // ответ «мимо, но +100 очков» нельзя; завысить yearPoints выше шкалы — тоже.
      function ownAnswerOk() {
        return !('answers' in request.resource.data)
          || !(request.auth.uid in request.resource.data.answers)
          || (
            request.resource.data.answers[request.auth.uid].points is int
            && request.resource.data.answers[request.auth.uid].points >= 0
            && request.resource.data.answers[request.auth.uid].points <= 100
            && request.resource.data.answers[request.auth.uid].yearPoints is int
            && request.resource.data.answers[request.auth.uid].yearPoints >= 0
            && request.resource.data.answers[request.auth.uid].yearPoints <= 50
            && (request.resource.data.answers[request.auth.uid].points == 0
                || request.resource.data.answers[request.auth.uid].choice
                   == resource.data.rounds[resource.data.current.index].correctIndex)
          );
      }

      // Запись разрешена, если ты:
      //  • хост — полный контроль над своей партией (фазы, раунды, счёт, лог);
      //  • участник — меняешь только свои players[uid]/answers[uid]/clockPings[uid],
      //    счёт себе не трогаешь, ответы — только во время раунда и в пределах шкалы,
      //    из playerOrder можешь убрать только себя (выход из лобби);
      //  • не участник — только присоединяешься (со счётом 0, пока лобби в ожидании
      //    и есть свободное место).
      // App Check отсекает запросы не от приложения; коды лобби 4-значные.
      allow update: if signedIn() && (
        resource.data.hostId == request.auth.uid
        || (
          request.auth.uid in resource.data.players
          && changedKeys().hasOnly(['players', 'playerOrder', 'answers', 'clockPings'])
          && onlyOwn('players') && onlyOwn('answers') && onlyOwn('clockPings')
          && ownScoreUnchanged()
          && ownPlayerOk()
          && ownAnswerOk()
          && (!changedKeys().hasAny(['answers'])
              || resource.data.current.phase == 'playing')
          && (request.resource.data.playerOrder == resource.data.playerOrder
              || request.resource.data.playerOrder == resource.data.playerOrder.removeAll([request.auth.uid]))
        )
        || (
          !(request.auth.uid in resource.data.players)
          && resource.data.status == 'waiting'
          && request.resource.data.players.size() <= maxPlayers()
          && changedKeys().hasOnly(['players', 'playerOrder'])
          && request.auth.uid in request.resource.data.players
          && onlyOwn('players')
          && request.resource.data.players[request.auth.uid].score == 0
          && ownPlayerOk()
          && (request.resource.data.playerOrder == resource.data.playerOrder.concat([request.auth.uid])
              || request.resource.data.playerOrder == resource.data.playerOrder)
        )
      );

      // Удалять активное лобби может только хост; лобби старше TTL — любой
      // (ленивая сборка мусора чужих заброшенных лобби в cleanupOldLobbies).
      allow delete: if signedIn() && (
        resource.data.hostId == request.auth.uid ||
        resource.data.createdAt < request.time - lobbyTtl()
      );
    }

    // Приглашения в лобби («недавно играли вместе»). Один документ на получателя:
    // последний зов перезаписывает предыдущий. Читает и удаляет только получатель;
    // отправить может любой авторизованный, но только от своего имени, со строгой
    // формой и серверным временем (фильтр устаревших приглашений на клиенте).
    match /invites/{uid} {
      allow read, delete: if signedIn() && request.auth.uid == uid;
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly(['code', 'fromUid', 'fromName', 'at'])
        && request.resource.data.code is string && request.resource.data.code.size() == 4
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromName is string && request.resource.data.fromName.size() <= 100
        && request.resource.data.at == request.time;
    }

    // Профили и таблица лидеров. Читать рейтинг может любой авторизованный.
    // Писать — только в свой документ, и счёт нельзя накрутить произвольно:
    // он растёт монотонно и не больше чем на одну партию за запись.
    match /users/{uid} {
      allow read: if signedIn();

      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.uid == uid
        && validUserData(request.resource.data)
        && request.resource.data.totalScore <= maxGameScore()
        && request.resource.data.gamesPlayed <= 1;

      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.uid == uid
        && validUserData(request.resource.data)
        && request.resource.data.totalScore >= resource.data.totalScore
        && request.resource.data.totalScore <= resource.data.totalScore + maxGameScore()
        && request.resource.data.gamesPlayed >= resource.data.gamesPlayed
        && request.resource.data.gamesPlayed <= resource.data.gamesPlayed + 1
        && request.resource.data.wins >= resource.data.wins
        && request.resource.data.wins <= resource.data.wins + 1;

      allow delete: if false;
    }
  }
}
